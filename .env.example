# Prep AI Environment Configuration Example

# Secret key for signing Flask sessions
SECRET_KEY=supersecretkeychangeinproduction

# Database Connection (MySQL)
# Format: mysql+pymysql://username:password@hostname:port/database_name
# Example: mysql+pymysql://root:password@localhost:3306/prep_ai
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/prep_ai

# Fallback Database (SQLite) - set to True to use sqlite for local testing without MySQL
USE_SQLITE_FALLBACK=True

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
